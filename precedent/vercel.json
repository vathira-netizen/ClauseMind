{
  "version": 2,
  "builds": [
    { "src": "frontend/**", "use": "@vercel/static" },
    { "src": "api/review.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/health", "dest": "/api/review.py" },
    { "src": "/api/review", "dest": "/api/review.py" },
    { "src": "/(.*)", "dest": "/frontend/index.html" }
  ]
}