# ---------------------------------------------------------------------------
# Precedent — environment configuration
# Copy to .env and fill in. Read (flat, no prefix) by src/precedent/config.py.
# ---------------------------------------------------------------------------

# Qdrant — institutional memory (clause_memory, playbook, counterparty_profiles)
QDRANT_URL=http://localhost:6333

# Google ADK / Gemini — orchestration layer
GOOGLE_API_KEY=
MODEL_NAME=gemini-2.0-flash

# Lyzr — governance layer
LYZR_API_KEY=

# API auth (JWT signing secret) — override in staging/production
JWT_SECRET=dev-secret-change-me

# OpenTelemetry — traces exported to Jaeger (see docker-compose.yml)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
